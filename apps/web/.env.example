PORT=3001

# SMTP opcional para recibir emails del formulario de contacto
SMTP_HOST=smtp.tuproveedor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=usuario@tudominio.com
SMTP_PASS=tu-password-o-token
CONTACT_FROM_EMAIL=portfolio@tudominio.com
CONTACT_TO_EMAIL=administracion@zuzudev.pro

# Opcional: webhook de n8n para automatizar cada consulta (notificaciones, CRM, agenda)
# N8N_WEBHOOK_URL=https://tu-servidor-n8n.com/webhook/contacto-zuzudev

# En produccion estas variables se configuran en Vercel -> Settings -> Environment Variables
